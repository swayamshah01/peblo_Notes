# Recommended local database config. This avoids DATABASE_URL encoding issues
# when your password contains special characters like @, #, %, :, or /.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=peblo_notes
DB_USER=postgres
DB_PASSWORD=your_postgres_password

# Optional alternative:
# DATABASE_URL=postgresql://postgres:your_postgres_password@localhost:5432/peblo_notes
JWT_SECRET=replace_with_a_long_random_secret
GROQ_API_KEY=replace_with_your_groq_api_key
GROQ_MODEL=llama-3.1-8b-instant
CLIENT_URL=http://localhost:5173
PORT=5000
